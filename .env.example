# ============================================
# sms-notify-app — environment variables
# Copy to .env (or .env.local) and fill in real values.
# DO NOT commit .env / .env.local to git.
# Placeholders below are intentionally invalid so a missing real value
# surfaces as a loud error at boot (see src/lib/env.ts).
# ============================================

# Runtime: development | test | production
# (optional — defaults to development)
NODE_ENV=development

# ----------------------------
# Database (Postgres)
# ----------------------------
# Neon / Supabase / Vercel Postgres / local — any Postgres 14+ works.
# Neon example:
#   postgres://USER:PASS@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/sms_notify_app

# ----------------------------
# Auth
# ----------------------------
# Used by NextAuth / iron-session to sign and encrypt session tokens.
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_32_plus_char_random_string

# ----------------------------
# Stripe (server-only)
# ----------------------------
# Test keys start with sk_test_, live with sk_live_.
STRIPE_SECRET_KEY=sk_test_replace_me
# Signing secret from the Stripe webhook endpoint (whsec_...).
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ----------------------------
# Twilio (server-only auth token, public account SID)
# ----------------------------
# Find in the Twilio console: Account -> API keys & tokens.
# Account SID starts with AC.
TWILIO_ACCOUNT_SID=ACreplace_me
TWILIO_AUTH_TOKEN=replace_me

# ----------------------------
# Public site origin
# ----------------------------
# Canonical public URL of the deployed app (no trailing slash).
APP_URL=http://localhost:3000
